# Serveur
PORT=3000
NODE_ENV=production

# Backend URL (URL publique HTTPS du backend, ex: https://api.skyrecharge.com)
BACKEND_URL=

# Base de données PostgreSQL
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=skyrecharge
DB_USER=skyrecharge_user
DB_PASSWORD=

# Babimo
BABIMO_BASE_URL=
BABIMO_EMAIL=
BABIMO_PASSWORD=
BABIMO_REFERENCE_CL=

# Redis (VPS: 127.0.0.1 en local, avec mot de passe requis)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=

# Wave API
WAVE_API_KEY=
WAVE_API_URL=

# SMS (Africa's Talking)
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# WhatsApp Support
WHATSAPP_NUMBER=

# MTN MoMo
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_ENV=
